---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const socials = [
  {
    label: 'Email',
    value: 'himehatsumi@duck.com',
    href: 'mailto:himehatsumi@duck.com',
    action: 'send mail',
    reliable: true,
    icon: 'mail',
  },
  {
    label: 'Discord',
    value: 'himehatsumi',
    copy: 'himehatsumi',
    action: 'copy name',
    reliable: true,
    icon: 'discord',
  },
  {
    label: 'Matrix',
    value: '@hime:matrix.melancho.li',
    href: 'https://matrix.to/#/@hime:matrix.melancho.li',
    action: 'open',
    reliable: true,
    icon: 'matrix',
  },
  {
    label: 'YouTube',
    value: '@himehatsumi',
    href: 'https://www.youtube.com/@himehatsumi',
    action: 'watch',
    reliable: false,
    icon: 'youtube',
  },
  {
    label: 'X / Twitter',
    value: '@himehatsumi',
    href: 'https://x.com/himehatsumi',
    action: 'open',
    reliable: false,
    icon: 'x',
  },
  {
    label: 'GitHub',
    value: 'himehatsumi',
    href: 'https://github.com/himehatsumi',
    action: 'view',
    reliable: false,
    icon: 'github',
  },
];

const reliableSocials = socials.filter((social) => social.reliable);

const icons: Record<string, string> = {
  mail: '<path d="M3.5 6.5h17v12h-17z"/><path d="m4 7 8 6 8-6"/>',
  discord: '<path class="fill-icon" d="M5.6 5.4a15.1 15.1 0 0 1 12.8 0c1.3 2.2 2 4.8 2.1 7.5a12.7 12.7 0 0 1-4.6 3.9l-1.1-1.6c.7-.3 1.4-.7 2.1-1.1a10.9 10.9 0 0 1-9.8 0c.7.4 1.4.8 2.1 1.1l-1.1 1.6a12.7 12.7 0 0 1-4.6-3.9c.1-2.7.8-5.3 2.1-7.5Zm3.5 7.1c.8 0 1.4-.7 1.4-1.6s-.6-1.6-1.4-1.6-1.4.7-1.4 1.6.6 1.6 1.4 1.6Zm5.8 0c.8 0 1.4-.7 1.4-1.6s-.6-1.6-1.4-1.6-1.4.7-1.4 1.6.6 1.6 1.4 1.6Z"/>',
  matrix: '<path d="M7 4H4v16h3M17 4h3v16h-3M9 9v7m0-5a2 2 0 0 1 4 0v5m0-5a2 2 0 0 1 4 0v5"/>',
  youtube: '<rect x="3" y="6" width="18" height="12" rx="3"/><path class="fill-icon" d="m10 9 5 3-5 3Z"/>',
  x: '<path class="fill-icon" d="M18.24 2.25h3.31l-7.23 8.26 8.51 11.24h-6.66l-5.21-6.82-5.97 6.82H1.68l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23Zm-1.16 17.52h1.83L7.08 4.13H5.12l11.96 15.64Z"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.3-.4 6.8-1.6 6.8-7A5.5 5.5 0 0 0 19.3 4 5.1 5.1 0 0 0 19.1.5S18 0 15 2a13.4 13.4 0 0 0-7 0C5-.1 3.9.5 3.9.5A5.1 5.1 0 0 0 3.7 4a5.5 5.5 0 0 0-1.5 3.8c0 5.4 3.5 6.6 6.8 7-.8.8-1 1.8-1 3.2v4m0-3c-3 .9-3-1.5-4-2"/>',
};
---

<Layout title="melancho.li — himehatsumi" description="Himehatsumi's personal website and contact links.">
  <a class="skip-link" href="#contact">skip to contact</a>

  <div class="site" id="home">
    <header class="site-header">
      <div class="top-strip">
        <span>melancho.li</span>
        <span>himehatsumi online</span>
      </div>

      <div class="banner">
        <div class="image-placeholder banner-placeholder" role="img" aria-label="Placeholder for a Monogatari banner image">
          <span>IMAGE HERE</span>
          <small>MONOGATARI BANNER // 1600 × 640</small>
        </div>
        <div class="banner-copy">
          <p lang="ja">私の小さな物語</p>
          <h1>melancho.li</h1>
          <span>himehatsumi’s personal website</span>
        </div>
      </div>

      <nav class="main-nav" aria-label="Main navigation">
        <a href="#home">home</a>
        <a href="#contact">contact</a>
        <a href="https://github.com/himehatsumi/melancho.li" target="_blank" rel="noreferrer">source</a>
      </nav>
    </header>

    <div class="page-grid">
      <aside class="left-sidebar" aria-label="Profile and site information">
        <section class="panel">
          <h2 class="panel-title">PROFILE.TXT</h2>
          <div class="image-crop portrait-crop image-placeholder" role="img" aria-label="Placeholder for a character portrait">
            <span>IMAGE HERE</span>
            <small>CHARACTER PORTRAIT</small>
          </div>
          <dl class="profile-list">
            <dt>name</dt><dd>himehatsumi</dd>
            <dt>site</dt><dd>melancho.li</dd>
            <dt>status</dt><dd>online</dd>
          </dl>
        </section>

        <section class="panel">
          <h2 class="panel-title">SITE MENU</h2>
          <ul class="side-links">
            <li><a href="#home">01. home</a></li>
            <li><a href="#contact">02. contact</a></li>
            <li><a href="#site-log">03. site log</a></li>
          </ul>
        </section>

        <section class="panel small-panel">
          <h2 class="panel-title">INTERESTS.TXT</h2>
          <p>monogatari<br />old web pages<br />quiet internet corners</p>
        </section>
      </aside>

      <main class="content">
        <section class="panel welcome-panel">
          <h2 class="panel-title">WELCOME</h2>
          <div class="panel-body">
            <p>Hi, I’m himehatsumi.</p>
            <p>This is my small place on the internet. I mostly use it to keep my links somewhere that belongs to me.</p>
            <p>If you actually need to reach me, email, Discord, and Matrix are the ones I check most.</p>
          </div>
        </section>

        <section class="panel contact-panel" id="contact">
          <div class="panel-heading">
            <h2 class="panel-title">CONTACT &amp; LINKS</h2>
            <p><b>*</b> checked most often</p>
          </div>

          <ul class="contact-list">
            {socials.map((social) => (
              <li class:list={{ reliable: social.reliable }}>
                {social.href ? (
                  <a
                    class="contact-row"
                    href={social.href}
                    target={social.href.startsWith('http') ? '_blank' : undefined}
                    rel={social.href.startsWith('http') ? 'me noreferrer' : undefined}
                  >
                    <span class="marker" aria-hidden="true">{social.reliable ? '*' : ''}</span>
                    <span class="contact-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="contact-info">
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="contact-action">{social.action}</span>
                  </a>
                ) : (
                  <button class="contact-row" type="button" data-copy={social.copy} aria-label={`Copy Discord username ${social.value}`}>
                    <span class="marker" aria-hidden="true">*</span>
                    <span class="contact-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="contact-info">
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="contact-action" aria-live="polite">{social.action}</span>
                  </button>
                )}
              </li>
            ))}
          </ul>
        </section>

        <section class="panel" id="site-log">
          <h2 class="panel-title">SITE LOG</h2>
          <div class="log-entry">
            <time datetime="2026-07-11">11.07.2026</time>
            <p>Rebuilt the page in black and white. Removed the motion and fixed the contact list.</p>
          </div>
        </section>
      </main>

      <aside class="right-sidebar" aria-label="Contact summary and artwork">
        <section class="panel">
          <h2 class="panel-title">MOST RELIABLE</h2>
          <ol class="reliable-list">
            {reliableSocials.map((social) => (
              <li>
                <strong>{social.label}</strong>
                <span>{social.value}</span>
              </li>
            ))}
          </ol>
        </section>

        <section class="panel">
          <h2 class="panel-title">MONOGATARI</h2>
          <div class="image-crop detail-crop image-placeholder" role="img" aria-label="Placeholder for a Monogatari detail image">
            <span>IMAGE HERE</span>
            <small>MANGA DETAIL</small>
          </div>
          <p class="caption">staplers / donuts / stairs</p>
        </section>

        <section class="panel small-panel">
          <h2 class="panel-title">ABOUT THIS PAGE</h2>
          <p>handmade with html, css, and one very small script.</p>
          <p class="best-viewed">best viewed in any browser</p>
        </section>
      </aside>
    </div>

    <footer class="footer">
      <span>© {new Date().getFullYear()} himehatsumi</span>
      <span>last updated: 11 july 2026</span>
    </footer>
  </div>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy]');

    copyButton?.addEventListener('click', async () => {
      const text = copyButton.dataset.copy;
      const label = copyButton.querySelector<HTMLElement>('.contact-action');
      if (!text || !label) return;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          const input = document.createElement('textarea');
          input.value = text;
          input.setAttribute('readonly', '');
          input.style.position = 'fixed';
          input.style.opacity = '0';
          document.body.appendChild(input);
          input.select();
          const legacyDocument = document as unknown as { execCommand: (command: string) => boolean };
          const copied = legacyDocument.execCommand('copy');
          input.remove();
          if (!copied) throw new Error('Copy was unavailable');
        }

        label.textContent = 'copied';
        window.setTimeout(() => { label.textContent = 'copy name'; }, 1800);
      } catch {
        label.textContent = text;
      }
    });
  </script>
</Layout>

<style>
  .skip-link {
    position: fixed;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 20;
    padding: 0.45rem 0.65rem;
    color: var(--white);
    background: var(--black);
    transform: translateY(-150%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site {
    width: min(calc(100% - 2rem), 980px);
    margin: 1.5rem auto;
    border: 1px solid var(--black);
    background: var(--white);
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.2);
  }

  .top-strip {
    display: flex;
    min-height: 1.7rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.25rem 0.65rem;
    color: var(--white);
    background: var(--black);
    font: 10px/1.2 var(--mono);
    text-transform: uppercase;
  }

  .banner {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--black);
    background: var(--white);
  }

  .banner-placeholder {
    width: 100%;
    min-height: 23.5rem;
    padding-left: 44%;
  }

  .banner-copy {
    position: absolute;
    top: 23%;
    left: 4.5%;
    width: 37%;
    padding: 1rem 1.1rem;
    border: 1px solid var(--black);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 3px 3px 0 var(--black);
  }

  .banner-copy p {
    margin: 0 0 0.2rem;
    font: 10px/1.2 var(--sans);
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 0;
    font: bold clamp(2rem, 5.2vw, 3.6rem)/0.95 var(--serif);
    letter-spacing: -0.06em;
  }

  .banner-copy > span {
    display: inline-block;
    margin-top: 0.55rem;
    border-bottom: 1px solid var(--black);
    font-size: 10px;
  }

  .main-nav {
    display: flex;
    justify-content: center;
    border-bottom: 1px solid var(--black);
    background: var(--gray-100);
  }

  .main-nav a {
    min-width: 7rem;
    padding: 0.45rem 1rem;
    border-right: 1px solid var(--black);
    text-align: center;
    text-decoration: none;
  }

  .main-nav a:first-child {
    border-left: 1px solid var(--black);
  }

  .main-nav a:hover {
    color: var(--white);
    background: var(--black);
  }

  .page-grid {
    display: grid;
    grid-template-areas: 'left content right';
    grid-template-columns: 185px minmax(0, 1fr) 185px;
  }

  .left-sidebar,
  .right-sidebar,
  .content {
    min-width: 0;
    padding: 0.75rem;
  }

  .left-sidebar { grid-area: left; }
  .content {
    grid-area: content;
    border-right: 1px solid var(--black);
    border-left: 1px solid var(--black);
  }
  .right-sidebar { grid-area: right; }

  .panel {
    margin-bottom: 0.8rem;
  }

  .panel-title {
    margin: 0;
    padding: 0.3rem 0.45rem;
    color: var(--white);
    background: var(--black);
    font: bold 10px/1.25 var(--mono);
    letter-spacing: 0.06em;
  }

  .panel-body,
  .small-panel > p {
    margin: 0;
    padding: 0.75rem;
    border: 1px solid var(--black);
    border-top: 0;
  }

  .panel-body p {
    margin: 0 0 0.7rem;
  }

  .panel-body p:last-child {
    margin-bottom: 0;
  }

  .image-crop {
    overflow: hidden;
    border: 1px solid var(--black);
    border-top: 0;
    background: var(--gray-100);
  }

  .image-placeholder {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    color: var(--gray-700);
    background:
      linear-gradient(45deg, transparent 49.7%, var(--gray-300) 49.8%, var(--gray-300) 50.2%, transparent 50.3%),
      linear-gradient(-45deg, transparent 49.7%, var(--gray-300) 49.8%, var(--gray-300) 50.2%, transparent 50.3%),
      repeating-linear-gradient(0deg, var(--white) 0 3px, var(--gray-100) 3px 4px);
    font: bold 12px/1.2 var(--mono);
    text-align: center;
  }

  .image-placeholder::after {
    content: '';
    position: absolute;
    inset: 0.45rem;
    border: 1px dotted var(--gray-500);
    pointer-events: none;
  }

  .image-placeholder span,
  .image-placeholder small {
    position: relative;
    z-index: 1;
    padding: 0.15rem 0.35rem;
    background: rgba(255, 255, 255, 0.92);
  }

  .image-placeholder small {
    font: 8px/1.3 var(--mono);
  }

  .portrait-crop {
    aspect-ratio: 1;
  }

  .detail-crop {
    aspect-ratio: 4 / 3;
  }

  .caption {
    margin: 0;
    padding: 0.3rem;
    border: 1px solid var(--black);
    border-top: 0;
    font: 9px/1.3 var(--mono);
    text-align: center;
  }

  .profile-list {
    display: grid;
    grid-template-columns: 3.3rem minmax(0, 1fr);
    margin: 0;
    border: 1px solid var(--black);
    border-top: 0;
    font-size: 10px;
  }

  .profile-list dt,
  .profile-list dd {
    margin: 0;
    padding: 0.3rem;
    border-bottom: 1px dotted var(--gray-500);
  }

  .profile-list dt {
    color: var(--gray-700);
    font-family: var(--mono);
  }

  .profile-list dt:last-of-type,
  .profile-list dd:last-of-type {
    border-bottom: 0;
  }

  .side-links {
    margin: 0;
    padding: 0;
    border: 1px solid var(--black);
    border-top: 0;
    list-style: none;
  }

  .side-links li + li {
    border-top: 1px dotted var(--gray-500);
  }

  .side-links a {
    display: block;
    padding: 0.35rem 0.5rem;
    font: 10px/1.4 var(--mono);
  }

  .side-links a:hover {
    color: var(--white);
    background: var(--black);
  }

  .panel-heading {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    background: var(--black);
  }

  .panel-heading p {
    margin: 0;
    padding: 0.3rem 0.45rem;
    color: var(--white);
    font: 9px/1.25 var(--mono);
  }

  .contact-list {
    margin: 0;
    padding: 0;
    border: 1px solid var(--black);
    border-top: 0;
    list-style: none;
  }

  .contact-list li + li {
    border-top: 1px dotted var(--gray-500);
  }

  .contact-list li:nth-child(even) {
    background: var(--gray-100);
  }

  .contact-list li.reliable {
    background: #e4e4e4;
  }

  .contact-row {
    display: grid;
    width: 100%;
    min-height: 3.9rem;
    grid-template-columns: 0.8rem 1.6rem minmax(0, 1fr) 5.2rem;
    gap: 0.45rem;
    align-items: center;
    padding: 0.55rem 0.65rem;
    border: 0;
    color: var(--black);
    background: transparent;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
  }

  .contact-row:hover {
    color: var(--white);
    background: var(--black);
  }

  .marker {
    font: bold 15px/1 var(--mono);
    text-align: center;
  }

  .contact-icon {
    display: grid;
    width: 1.6rem;
    height: 1.6rem;
    place-items: center;
  }

  .contact-icon svg {
    display: block;
    width: 1.15rem;
    height: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.35;
  }

  .contact-icon :global(.fill-icon) {
    fill: currentColor;
    stroke: none;
  }

  .contact-info {
    display: grid;
    min-width: 0;
    grid-template-columns: 6.2rem minmax(0, 1fr);
    gap: 0.5rem;
    align-items: baseline;
  }

  .contact-info strong {
    font-size: 11px;
  }

  .contact-info small {
    overflow-wrap: anywhere;
    font: 10px/1.4 var(--mono);
  }

  .contact-action {
    justify-self: end;
    font: 9px/1.3 var(--mono);
    text-decoration: underline;
  }

  .log-entry {
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    border: 1px solid var(--black);
    border-top: 0;
  }

  .log-entry time,
  .log-entry p {
    margin: 0;
    padding: 0.65rem;
  }

  .log-entry time {
    border-right: 1px dotted var(--gray-500);
    font: 10px/1.4 var(--mono);
  }

  .reliable-list {
    margin: 0;
    padding: 0;
    border: 1px solid var(--black);
    border-top: 0;
    list-style: none;
    counter-reset: contacts;
  }

  .reliable-list li {
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    counter-increment: contacts;
  }

  .reliable-list li + li {
    border-top: 1px dotted var(--gray-500);
  }

  .reliable-list strong::before {
    content: '0' counter(contacts) '. ';
    font-family: var(--mono);
  }

  .reliable-list span {
    margin-left: 1.55rem;
    font: 9px/1.4 var(--mono);
    overflow-wrap: anywhere;
  }

  .best-viewed {
    border-top: 1px dotted var(--gray-500);
    font: 9px/1.4 var(--mono);
    text-align: center;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.4rem 0.65rem;
    color: var(--white);
    background: var(--black);
    font: 9px/1.4 var(--mono);
  }

  @media (max-width: 800px) {
    .page-grid {
      grid-template-areas:
        'content'
        'left'
        'right';
      grid-template-columns: 1fr;
    }

    .content {
      border-right: 0;
      border-left: 0;
    }

    .left-sidebar,
    .right-sidebar {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      border-top: 1px solid var(--black);
    }

    .left-sidebar .panel,
    .right-sidebar .panel {
      margin-bottom: 0;
    }
  }

  @media (max-width: 560px) {
    .site {
      width: 100%;
      margin: 0;
      border-right: 0;
      border-left: 0;
      box-shadow: none;
    }

    .banner-placeholder {
      min-height: 12rem;
      padding-left: 0;
    }

    .banner-copy {
      position: static;
      width: auto;
      padding: 0.85rem;
      border: 0;
      border-top: 1px solid var(--black);
      box-shadow: none;
    }

    h1 {
      font-size: 2.35rem;
    }

    .main-nav a {
      min-width: 0;
      flex: 1;
    }

    .left-sidebar,
    .right-sidebar {
      grid-template-columns: 1fr;
    }

    .contact-row {
      grid-template-columns: 0.7rem 1.5rem minmax(0, 1fr);
      gap: 0.4rem;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    .contact-action {
      grid-column: 3;
      justify-self: start;
    }

    .footer {
      flex-direction: column;
      gap: 0.15rem;
    }
  }
</style>
