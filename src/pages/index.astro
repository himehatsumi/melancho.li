---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import avatarLeft from '../assets/images/avatar-left.jpg';
import avatarRight from '../assets/images/avatar-right.jpg';
import bannerImage from '../assets/images/banner.jpg';
import '../styles/global.css';

const socials = [
  {
    label: 'Email',
    value: 'himehatsumi@duck.com',
    href: 'mailto:himehatsumi@duck.com',
    action: 'send mail',
    reliable: true,
    icon: 'mail',
  },
  {
    label: 'Discord',
    value: 'himehatsumi',
    copy: 'himehatsumi',
    action: 'copy name',
    reliable: true,
    icon: 'discord',
  },
  {
    label: 'Matrix',
    value: '@hime:matrix.melancho.li',
    href: 'https://matrix.to/#/@hime:matrix.melancho.li',
    action: 'open',
    reliable: true,
    icon: 'matrix',
  },
  {
    label: 'YouTube',
    value: '@himehatsumi',
    href: 'https://www.youtube.com/@himehatsumi',
    action: 'watch',
    reliable: false,
    icon: 'youtube',
  },
  {
    label: 'X / Twitter',
    value: '@himehatsumi',
    href: 'https://x.com/himehatsumi',
    action: 'open',
    reliable: false,
    icon: 'x',
  },
  {
    label: 'GitHub',
    value: 'himehatsumi',
    href: 'https://github.com/himehatsumi',
    action: 'view',
    reliable: false,
    icon: 'github',
  },
];

const reliableSocials = socials.filter((social) => social.reliable);

const icons: Record<string, string> = {
  mail: '<path d="M3.5 6.5h17v12h-17z"/><path d="m4 7 8 6 8-6"/>',
  discord: '<path class="fill-icon" d="M5.6 5.4a15.1 15.1 0 0 1 12.8 0c1.3 2.2 2 4.8 2.1 7.5a12.7 12.7 0 0 1-4.6 3.9l-1.1-1.6c.7-.3 1.4-.7 2.1-1.1a10.9 10.9 0 0 1-9.8 0c.7.4 1.4.8 2.1 1.1l-1.1 1.6a12.7 12.7 0 0 1-4.6-3.9c.1-2.7.8-5.3 2.1-7.5Zm3.5 7.1c.8 0 1.4-.7 1.4-1.6s-.6-1.6-1.4-1.6-1.4.7-1.4 1.6.6 1.6 1.4 1.6Zm5.8 0c.8 0 1.4-.7 1.4-1.6s-.6-1.6-1.4-1.6-1.4.7-1.4 1.6.6 1.6 1.4 1.6Z"/>',
  matrix: '<path d="M7 4H4v16h3M17 4h3v16h-3M9 9v7m0-5a2 2 0 0 1 4 0v5m0-5a2 2 0 0 1 4 0v5"/>',
  youtube: '<rect x="3" y="6" width="18" height="12" rx="3"/><path class="fill-icon" d="m10 9 5 3-5 3Z"/>',
  x: '<path class="fill-icon" d="M18.24 2.25h3.31l-7.23 8.26 8.51 11.24h-6.66l-5.21-6.82-5.97 6.82H1.68l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23Zm-1.16 17.52h1.83L7.08 4.13H5.12l11.96 15.64Z"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.3-.4 6.8-1.6 6.8-7A5.5 5.5 0 0 0 19.3 4 5.1 5.1 0 0 0 19.1.5S18 0 15 2a13.4 13.4 0 0 0-7 0C5-.1 3.9.5 3.9.5A5.1 5.1 0 0 0 3.7 4a5.5 5.5 0 0 0-1.5 3.8c0 5.4 3.5 6.6 6.8 7-.8.8-1 1.8-1 3.2v4m0-3c-3 .9-3-1.5-4-2"/>',
};
---

<Layout title="melancho.li — himehatsumi" description="Himehatsumi's personal website and contact links.">
  <a class="skip-link" href="#contact">skip to contact</a>

  <div class="quote-rail quote-rail-left" aria-hidden="true">
    <div class="quote-stream">全ての〈物語〉はここから始まる　／　傷物語　／　全ての〈物語〉のはじまりを、ふたたび</div>
  </div>
  <div class="quote-rail quote-rail-right" aria-hidden="true">
    <div class="quote-stream">全ての〈物語〉のはじまりを、ふたたび　／　傷物語　／　全ての〈物語〉はここから始まる</div>
  </div>

  <div class="site" id="home">
    <header class="site-header">
      <div class="top-strip">
        <span>melancho.li</span>
      </div>

      <div class="banner">
        <Image
          src={bannerImage}
          class="banner-image"
          alt="Monochrome Monogatari character surrounded by feathers"
          format="webp"
          quality={85}
          widths={[480, 720, 890]}
          sizes="(max-width: 560px) 100vw, 980px"
          priority
        />
        <div class="banner-copy">
          <p lang="ja">私の小さな物語</p>
          <h1>melancho.li</h1>
          <span>himehatsumi’s personal website</span>
        </div>
      </div>

      <nav class="main-nav" aria-label="Main navigation">
        <a href="#home">home</a>
        <a href="#contact">contact</a>
        <a href="https://github.com/himehatsumi/melancho.li" target="_blank" rel="noreferrer">source</a>
      </nav>
    </header>

    <div class="page-grid">
      <aside class="left-sidebar" aria-label="Profile and site information">
        <section class="panel">
          <h2 class="panel-title">PROFILE.TXT</h2>
          <div class="image-crop portrait-crop">
            <Image
              src={avatarLeft}
              class="panel-image"
              alt="Black-and-white Monogatari character portrait"
              format="webp"
              quality={85}
              widths={[185, 370, 736]}
              sizes="(max-width: 560px) calc(100vw - 24px), (max-width: 800px) 50vw, 185px"
            />
          </div>
          <dl class="profile-list">
            <dt>name</dt><dd>himehatsumi</dd>
            <dt>birthday</dt><dd><time datetime="2005-07-16">16.07 · age <span data-age>20</span></time></dd>
            <dt>status</dt><dd>online</dd>
          </dl>
        </section>

        <section class="panel">
          <h2 class="panel-title">SITE MENU</h2>
          <ul class="side-links">
            <li><a href="#home">01. home</a></li>
            <li><a href="#contact">02. contact</a></li>
            <li><a href="#site-log">03. site log</a></li>
          </ul>
        </section>

        <section class="panel small-panel">
          <h2 class="panel-title">INTERESTS</h2>
          <p>touhou<br />monogatari<br />retro tech<br />anime</p>
        </section>

        <section class="panel anilist-panel" data-anilist-widget>
          <h2 class="panel-title">ANILIST</h2>
          <a class="anilist-body" href="https://anilist.co/user/7043262" target="_blank" rel="noreferrer">
            <strong>@himehatsumi</strong>
            <span data-anilist-current aria-live="polite">watching: Chi. Chikyuu no Undou ni Tsuite — ep. 8</span>
            <span data-anilist-stats>181 anime / 962h watched</span>
            <u>view profile →</u>
          </a>
        </section>

        <section class="panel buttons-panel" aria-label="Web buttons">
          <h2 class="panel-title">BUTTONS</h2>
          <div class="button-shelf">
            <img src="/buttons/debian-powered.gif" width="88" height="31" alt="Powered by Debian" loading="lazy" decoding="async" />
            <img src="/buttons/mafumafu.gif" width="88" height="31" alt="Mafumafu" loading="lazy" decoding="async" />
          </div>
        </section>
      </aside>

      <main class="content">
        <section class="panel welcome-panel">
          <h2 class="panel-title">WELCOME</h2>
          <div class="panel-body">
            <p>Hi, I'm himehatsumi.</p>
            <p>This is my personal website dedicated to my interests and my contact information.</p>
            <p>If you actually need to reach me, E-mail, Discord, and Matrix are the ones I check most.</p>
          </div>
        </section>

        <section class="panel contact-panel" id="contact">
          <div class="panel-heading">
            <h2 class="panel-title">CONTACT &amp; LINKS</h2>
            <p><b>*</b> checked most often</p>
          </div>

          <ul class="contact-list">
            {socials.map((social) => (
              <li class:list={{ reliable: social.reliable }}>
                {social.href ? (
                  <a
                    class="contact-row"
                    href={social.href}
                    target={social.href.startsWith('http') ? '_blank' : undefined}
                    rel={social.href.startsWith('http') ? 'me noreferrer' : undefined}
                  >
                    <span class="marker" aria-hidden="true">{social.reliable ? '*' : ''}</span>
                    <span class="contact-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="contact-info">
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="contact-action">{social.action}</span>
                  </a>
                ) : (
                  <button class="contact-row" type="button" data-copy={social.copy} aria-label={`Copy Discord username ${social.value}`}>
                    <span class="marker" aria-hidden="true">*</span>
                    <span class="contact-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="contact-info">
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="contact-action" aria-live="polite">{social.action}</span>
                  </button>
                )}
              </li>
            ))}
          </ul>
        </section>

        <section class="panel" id="site-log">
          <h2 class="panel-title">SITE LOG</h2>
          <div class="log-entry">
            <time datetime="2026-07-12">12.07.2026</time>
            <p>Added an automatic birthday age and updated the panel labels.</p>
          </div>
          <div class="log-entry">
            <time datetime="2026-07-11">11.07.2026</time>
            <p>Enlarged the desktop frame, type, and artwork panels for a roomier layout.</p>
          </div>
          <div class="log-entry">
            <time datetime="2026-07-11">11.07.2026</time>
            <p>Made the desktop frame taller and moved it lower on the page.</p>
          </div>
          <div class="log-entry">
            <time datetime="2026-07-11">11.07.2026</time>
            <p>Widened the layout and refreshed the about text and Monogatari quote.</p>
          </div>
        </section>
      </main>

      <aside class="right-sidebar" aria-label="Contact summary and artwork">
        <section class="panel">
          <h2 class="panel-title">MOST RELIABLE</h2>
          <ol class="reliable-list">
            {reliableSocials.map((social) => (
              <li>
                <strong>{social.label}</strong>
                <span>{social.value}</span>
              </li>
            ))}
          </ol>
        </section>

        <section class="panel">
          <h2 class="panel-title">MONOGATARI</h2>
          <div class="image-crop detail-crop">
            <Image
              src={avatarRight}
              class="panel-image"
              alt="Black-and-white Monogatari character portrait"
              format="webp"
              quality={85}
              widths={[185, 370, 740]}
              sizes="(max-width: 560px) calc(100vw - 24px), (max-width: 800px) 50vw, 185px"
            />
          </div>
          <p class="caption" lang="ja">「失礼。噛みました。」</p>
        </section>

        <section class="panel small-panel">
          <h2 class="panel-title">ABOUT THIS PAGE</h2>
          <p>built with Astro, HTML, CSS, and a little JavaScript.</p>
          <p class="best-viewed">best viewed on desktop</p>
        </section>

        <section class="panel clock-panel">
          <h2 class="panel-title">CLOCK</h2>
          <div class="clock-body">
            <time data-clock-time datetime="">--:--:--</time>
            <span data-clock-date>loading local time</span>
          </div>
        </section>

        <section class="panel weather-panel" data-weather-widget>
          <h2 class="panel-title">WEATHER</h2>
          <div class="weather-days" data-weather-days aria-live="polite" aria-busy="true">
            {[0, 1, 2].map(() => (
              <article class="weather-day" data-weather-day>
                <span class="weather-weekday">---</span>
                <strong class="weather-mark" aria-hidden="true">·</strong>
                <span class="weather-condition">loading</span>
                <span class="weather-temp">--° / --°</span>
              </article>
            ))}
          </div>
        </section>
      </aside>
    </div>

    <footer class="footer">
      <span>© {new Date().getFullYear()} himehatsumi</span>
      <span class="hit-counter" title="Shared visitor count">
        hits: <output data-hit-counter aria-live="polite">------</output>
      </span>
      <span>last updated: 12 july 2026</span>
      <p class="image-rights">Images from Monogatari belong to NISIOISIN and their respective copyright holders. No ownership claimed.</p>
    </footer>
  </div>

  <script>
    import { initializeApp } from 'firebase/app';
    import {
      connectFirestoreEmulator,
      doc,
      getDoc,
      getFirestore,
      runTransaction,
    } from 'firebase/firestore/lite';

    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy]');

    copyButton?.addEventListener('click', async () => {
      const text = copyButton.dataset.copy;
      const label = copyButton.querySelector<HTMLElement>('.contact-action');
      if (!text || !label) return;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          const input = document.createElement('textarea');
          input.value = text;
          input.setAttribute('readonly', '');
          input.style.position = 'fixed';
          input.style.opacity = '0';
          document.body.appendChild(input);
          input.select();
          const legacyDocument = document as unknown as { execCommand: (command: string) => boolean };
          const copied = legacyDocument.execCommand('copy');
          input.remove();
          if (!copied) throw new Error('Copy was unavailable');
        }

        label.textContent = 'copied';
        window.setTimeout(() => { label.textContent = 'copy name'; }, 1800);
      } catch {
        label.textContent = text;
      }
    });

    const anilistWidget = document.querySelector<HTMLElement>('[data-anilist-widget]');
    const anilistCurrent = anilistWidget?.querySelector<HTMLElement>('[data-anilist-current]');
    const anilistStats = anilistWidget?.querySelector<HTMLElement>('[data-anilist-stats]');
    const anilistLink = anilistWidget?.querySelector<HTMLAnchorElement>('.anilist-body');

    const anilistQuery = `
      query ($name: String) {
        User(name: $name) {
          siteUrl
          statistics { anime { count minutesWatched } }
        }
        Page(page: 1, perPage: 1) {
          mediaList(userName: $name, type: ANIME, status: CURRENT, sort: UPDATED_TIME_DESC) {
            progress
            media { title { userPreferred } }
          }
        }
      }
    `;

    if (anilistWidget && anilistCurrent && anilistStats) {
      fetch('https://graphql.anilist.co', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ query: anilistQuery, variables: { name: 'himehatsumi' } }),
      })
        .then((response) => {
          if (!response.ok) throw new Error('AniList request failed');
          return response.json();
        })
        .then((payload) => {
          const user = payload.data?.User;
          const current = payload.data?.Page?.mediaList?.[0];
          if (!user) return;

          if (current) {
            anilistCurrent.textContent = `watching: ${current.media.title.userPreferred} — ep. ${current.progress}`;
          } else {
            anilistCurrent.textContent = 'nothing marked as watching';
          }

          const animeCount = user.statistics?.anime?.count ?? 0;
          const hoursWatched = Math.round((user.statistics?.anime?.minutesWatched ?? 0) / 60);
          anilistStats.textContent = `${animeCount} anime / ${hoursWatched}h watched`;
          if (anilistLink && user.siteUrl) anilistLink.href = user.siteUrl;
        })
        .catch(() => {
          // The verified static snapshot remains visible when AniList is unavailable.
        });
    }

    const clockTime = document.querySelector<HTMLTimeElement>('[data-clock-time]');
    const clockDate = document.querySelector<HTMLElement>('[data-clock-date]');

    const updateClock = () => {
      if (!clockTime || !clockDate) return;
      const now = new Date();
      clockTime.dateTime = now.toISOString();
      clockTime.textContent = now.toLocaleTimeString([], {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false,
      });
      clockDate.textContent = now.toLocaleDateString([], {
        weekday: 'short',
        day: '2-digit',
        month: 'short',
        year: 'numeric',
      });
    };

    updateClock();
    window.setInterval(updateClock, 1000);

    const weatherDays = document.querySelectorAll<HTMLElement>('[data-weather-day]');
    const weatherDaysContainer = document.querySelector<HTMLElement>('[data-weather-days]');

    const describeWeather = (code: number) => {
      if (code === 0) return { label: 'clear', mark: '☆' };
      if (code <= 2) return { label: 'fair', mark: '◐' };
      if (code === 3) return { label: 'cloudy', mark: '●' };
      if (code === 45 || code === 48) return { label: 'fog', mark: '≋' };
      if (code >= 51 && code <= 57) return { label: 'drizzle', mark: '⋮' };
      if ((code >= 61 && code <= 67) || (code >= 80 && code <= 82)) return { label: 'rain', mark: '╱╱' };
      if ((code >= 71 && code <= 77) || code === 85 || code === 86) return { label: 'snow', mark: '✳' };
      if (code >= 95) return { label: 'storm', mark: 'ϟ' };
      return { label: 'mixed', mark: '?' };
    };

    if (weatherDays.length && weatherDaysContainer) {
      fetch('https://api.open-meteo.com/v1/forecast?latitude=48.09345&longitude=9.79053&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=Europe%2FBerlin&forecast_days=3')
        .then((response) => {
          if (!response.ok) throw new Error('Weather request failed');
          return response.json();
        })
        .then((forecast) => {
          weatherDays.forEach((day, index) => {
            const date = forecast.daily?.time?.[index];
            const code = Number(forecast.daily?.weather_code?.[index]);
            const high = Number(forecast.daily?.temperature_2m_max?.[index]);
            const low = Number(forecast.daily?.temperature_2m_min?.[index]);
            if (!date || !Number.isFinite(code) || !Number.isFinite(high) || !Number.isFinite(low)) return;

            const condition = describeWeather(code);
            const weekday = day.querySelector<HTMLElement>('.weather-weekday');
            const mark = day.querySelector<HTMLElement>('.weather-mark');
            const label = day.querySelector<HTMLElement>('.weather-condition');
            const temperature = day.querySelector<HTMLElement>('.weather-temp');

            if (weekday) {
              weekday.textContent = index === 0
                ? 'today'
                : new Date(`${date}T12:00:00`).toLocaleDateString([], { weekday: 'short' });
            }
            if (mark) mark.textContent = condition.mark;
            if (label) label.textContent = condition.label;
            if (temperature) temperature.textContent = `${Math.round(high)}° / ${Math.round(low)}°`;
          });

          weatherDaysContainer.removeAttribute('aria-busy');
        })
        .catch(() => {
          weatherDaysContainer.removeAttribute('aria-busy');
          weatherDaysContainer.textContent = 'forecast unavailable';
        });
    }

    const age = document.querySelector<HTMLElement>('[data-age]');
    const updateAge = () => {
      if (!age) return;
      const now = new Date();
      const birthdayHasPassed = now.getMonth() > 6 || (now.getMonth() === 6 && now.getDate() >= 16);
      age.textContent = String(now.getFullYear() - 2005 - (birthdayHasPassed ? 0 : 1));
    };

    updateAge();
    window.setInterval(updateAge, 60 * 1000);

    const hitCounter = document.querySelector<HTMLOutputElement>('[data-hit-counter]');
    if (hitCounter) {
      let shouldIncrement = true;
      try {
        shouldIncrement = sessionStorage.getItem('melancholi-hit-recorded') !== 'yes';
      } catch {
        // A shared count still works when session storage is unavailable.
      }

      const updateSharedCounter = async () => {
        const configResponse = await fetch('/__/firebase/init.json', { cache: 'no-store' });
        if (!configResponse.ok) throw new Error('Firebase configuration unavailable');

        const firebaseApp = initializeApp(await configResponse.json());
        const database = getFirestore(firebaseApp);

        if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
          connectFirestoreEmulator(database, '127.0.0.1', 8080);
        }

        const counterDocument = doc(database, 'site', 'hits');
        let count = 0;

        if (shouldIncrement) {
          count = await runTransaction(database, async (transaction) => {
            const snapshot = await transaction.get(counterDocument);
            const storedCount = snapshot.exists() ? snapshot.data().count : 0;
            const currentCount = Number.isSafeInteger(storedCount) && storedCount >= 0 ? storedCount : 0;
            const nextCount = currentCount + 1;
            transaction.set(counterDocument, { count: nextCount });
            return nextCount;
          });
        } else {
          const snapshot = await getDoc(counterDocument);
          const storedCount = snapshot.exists() ? snapshot.data().count : 0;
          count = Number.isSafeInteger(storedCount) && storedCount >= 0 ? storedCount : 0;
        }

        const displayCount = String(count).padStart(6, '0');
        hitCounter.value = displayCount;
        hitCounter.textContent = displayCount;

        if (shouldIncrement) {
          try {
            sessionStorage.setItem('melancholi-hit-recorded', 'yes');
          } catch {
            // The shared count has already been updated.
          }
        }
      };

      updateSharedCounter().catch(() => {
        hitCounter.value = '------';
        hitCounter.textContent = '------';
      });
    }
  </script>
</Layout>

<style>
  .skip-link {
    position: fixed;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 20;
    padding: 0.45rem 0.65rem;
    color: var(--white);
    background: var(--black);
    transform: translateY(-150%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .quote-rail {
    position: fixed;
    top: 0;
    bottom: 0;
    z-index: 0;
    width: 2rem;
    overflow: hidden;
    color: var(--gray-700);
    font: 10px/1.8 var(--serif);
    letter-spacing: 0.16em;
    pointer-events: none;
    writing-mode: vertical-rl;
  }

  .quote-rail-left {
    left: calc(50% - 645px);
  }

  .quote-rail-right {
    right: calc(50% - 645px);
  }

  .quote-stream {
    position: absolute;
    top: 0;
    white-space: nowrap;
    animation: quote-waterfall 44s linear infinite;
  }

  .quote-rail-right .quote-stream {
    animation-delay: -22s;
  }

  @keyframes quote-waterfall {
    from { transform: translateY(-110%); }
    to { transform: translateY(100vh); }
  }

  .site {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 2rem), 1180px);
    margin: 1.5rem auto;
    border: 1px solid var(--black);
    background: var(--white);
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.2);
  }

  .top-strip {
    display: flex;
    min-height: 1.7rem;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    padding: 0.25rem 0.65rem;
    color: var(--white);
    background: var(--black);
    font: 10px/1.2 var(--mono);
    text-transform: uppercase;
  }

  .banner {
