---
import '@fontsource-variable/dm-sans/index.css';
import '@fontsource-variable/fraunces/index.css';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const socials = [
  {
    label: 'Email',
    value: 'himehatsumi@duck.com',
    href: 'mailto:himehatsumi@duck.com',
    icon: 'mail',
    action: 'send mail',
    reliable: true,
  },
  {
    label: 'Discord',
    value: 'himehatsumi',
    copy: 'himehatsumi',
    icon: 'discord',
    action: 'copy username',
    reliable: true,
  },
  {
    label: 'Matrix',
    value: '@hime:matrix.melancho.li',
    href: 'https://matrix.to/#/@hime:matrix.melancho.li',
    icon: 'matrix',
    action: 'open matrix',
    reliable: true,
  },
  {
    label: 'YouTube',
    value: '@himehatsumi',
    href: 'https://www.youtube.com/@himehatsumi',
    icon: 'youtube',
    action: 'watch',
    reliable: false,
  },
  {
    label: 'Twitter / X',
    value: '@himehatsumi',
    href: 'https://x.com/himehatsumi',
    icon: 'twitter',
    action: 'open profile',
    reliable: false,
  },
  {
    label: 'GitHub',
    value: 'himehatsumi',
    href: 'https://github.com/himehatsumi',
    icon: 'github',
    action: 'see projects',
    reliable: false,
  },
];

const reliableSocials = socials.filter((social) => social.reliable);
const otherSocials = socials.filter((social) => !social.reliable);

const icons: Record<string, string> = {
  mail: '<path d="M4 7.5 12 13l8-5.5M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/>',
  youtube: '<path d="M21 12s0-3.2-.4-4.7a2.7 2.7 0 0 0-1.9-1.9C17.2 5 12 5 12 5s-5.2 0-6.7.4a2.7 2.7 0 0 0-1.9 1.9C3 8.8 3 12 3 12s0 3.2.4 4.7a2.7 2.7 0 0 0 1.9 1.9c1.5.4 6.7.4 6.7.4s5.2 0 6.7-.4a2.7 2.7 0 0 0 1.9-1.9C21 15.2 21 12 21 12Z"/><path d="m10 9 5 3-5 3V9Z"/>',
  discord: '<path d="M8 7a12 12 0 0 1 8 0m-9.5 9.5C4.5 15 4 10 5 7.5m12.5 9c2-1.5 2.5-6.5 1.5-9M9 17l1.2-1.5m4.8 1.5-1.2-1.5M9 12h.01M15 12h.01"/>',
  matrix: '<path d="M7 4H4v16h3M17 4h3v16h-3M9 9v7m0-5a2 2 0 0 1 4 0v5m0-5a2 2 0 0 1 4 0v5"/>',
  twitter: '<path d="M5 5l14 14M19 5 5 19"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.3-.4 6.8-1.6 6.8-7A5.5 5.5 0 0 0 19.3 4 5.1 5.1 0 0 0 19.1.5S18 0 15 2a13.4 13.4 0 0 0-7 0C5-.1 3.9.5 3.9.5A5.1 5.1 0 0 0 3.7 4a5.5 5.5 0 0 0-1.5 3.8c0 5.4 3.5 6.6 6.8 7-.8.8-1 1.8-1 3.2v4m0-3c-3 .9-3-1.5-4-2"/>',
};
---

<Layout title="melancho.li — himehatsumi" description="Himehatsumi's personal website and social links.">
  <a class="skip-link" href="#socials">Skip to socials</a>

  <header class="topbar shell" aria-label="Site header">
    <a class="home-link" href="#top">himehatsumi</a>
    <a class="social-jump" href="#socials">find me <span aria-hidden="true">↓</span></a>
  </header>

  <main>
    <section class="hero-scroll" id="top" data-hero aria-labelledby="page-title">
      <div class="hero-sticky">
        <svg class="sakura-art" viewBox="0 0 640 660" aria-hidden="true">
          <defs>
            <g id="sakura-blossom">
              <ellipse cy="-11" rx="7" ry="12" fill="currentColor"></ellipse>
              <ellipse cy="-11" rx="7" ry="12" fill="currentColor" transform="rotate(72)"></ellipse>
              <ellipse cy="-11" rx="7" ry="12" fill="currentColor" transform="rotate(144)"></ellipse>
              <ellipse cy="-11" rx="7" ry="12" fill="currentColor" transform="rotate(216)"></ellipse>
              <ellipse cy="-11" rx="7" ry="12" fill="currentColor" transform="rotate(288)"></ellipse>
              <circle r="3.5" fill="#a95878"></circle>
            </g>
          </defs>

          <path class="branch" d="M665 16C556 72 562 161 468 205c-69 32-125 24-168 90-34 52-75 76-139 91"></path>
          <path class="branch branch-fine" d="M510 181c-48-35-73-72-91-125M438 218c-47-39-91-55-145-64M326 270c-38-27-78-36-121-34M272 321c-27 5-55 23-76 51"></path>
          <path class="twig" d="M419 57c17 25 20 52 18 79M292 155c15 18 20 40 18 64M205 236c13 16 17 34 14 52"></path>

          <g class="flowers">
            <use href="#sakura-blossom" style="color:#efb2c6" transform="translate(414 52) rotate(-12)"></use>
            <use href="#sakura-blossom" style="color:#f4c5d4" transform="translate(437 132) scale(.82)"></use>
            <use href="#sakura-blossom" style="color:#ecacc2" transform="translate(487 195) rotate(19)"></use>
            <use href="#sakura-blossom" style="color:#f2bdcf" transform="translate(345 207) scale(.9)"></use>
            <use href="#sakura-blossom" style="color:#e99fba" transform="translate(291 151) rotate(-24)"></use>
            <use href="#sakura-blossom" style="color:#f4c5d4" transform="translate(249 260) scale(.78)"></use>
            <use href="#sakura-blossom" style="color:#efb2c6" transform="translate(183 379) rotate(16)"></use>
          </g>

          <path class="petal petal-one" d="M470 321c-12-7-12-18 2-22 10 7 10 16-2 22Z"></path>
          <path class="petal petal-two" d="M382 383c-10-10-7-20 8-20 8 9 5 17-8 20Z"></path>
          <path class="petal petal-three" d="M535 406c-11-6-12-16 1-20 10 6 10 14-1 20Z"></path>
        </svg>

        <div class="hero-content shell">
          <p class="welcome">hello, welcome to</p>
          <h1 id="page-title">melancho<span>.</span>li</h1>
          <p class="subtitle"><span>himehatsumi’s personal website.</span></p>
        </div>

        <a class="scroll-note" href="#socials">
          <span>keep scrolling</span>
          <span class="scroll-line" aria-hidden="true"></span>
        </a>
      </div>
    </section>

    <section class="social-section" id="socials" aria-labelledby="social-heading">
      <div class="shell">
        <div class="section-heading">
          <p>find me elsewhere</p>
          <h2 id="social-heading">Where to<br />reach me.</h2>
          <p class="section-copy">Email, Discord, and Matrix are the ones I actually check.</p>
        </div>

        <div class="contact-groups">
          <section class="contact-group reliable-group" aria-labelledby="reliable-heading">
            <h3 id="reliable-heading">the ones I check most</h3>
            <div class="reliable-list">
              {reliableSocials.map((social) => (
                social.href ? (
                  <a
                    class="contact-row reliable-contact"
                    href={social.href}
                    target={social.href.startsWith('http') ? '_blank' : undefined}
                    rel={social.href.startsWith('http') ? 'me noreferrer' : undefined}
                  >
                    <span class="icon-wrap" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="social-text">
                      <span class="reliable-note"><span aria-hidden="true">✿</span> most reliable</span>
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="card-action" aria-hidden="true">{social.action} ↗</span>
                  </a>
                ) : (
                  <button
                    class="contact-row reliable-contact copy-card"
                    type="button"
                    data-copy={social.copy}
                    aria-label={`Copy Discord username ${social.value}`}
                  >
                    <span class="icon-wrap" aria-hidden="true">
                      <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                    </span>
                    <span class="social-text">
                      <span class="reliable-note"><span aria-hidden="true">✿</span> most reliable</span>
                      <strong>{social.label}</strong>
                      <small>{social.value}</small>
                    </span>
                    <span class="card-action" aria-live="polite">{social.action}</span>
                  </button>
                )
              ))}
            </div>
          </section>

          <section class="contact-group other-group" aria-labelledby="other-heading">
            <h3 id="other-heading">also around here</h3>
            <div class="other-list">
              {otherSocials.map((social) => (
                <a
                  class="other-contact"
                  href={social.href}
                  target="_blank"
                  rel="me noreferrer"
                >
                  <span class="icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" set:html={icons[social.icon]}></svg>
                  </span>
                  <span class="social-text">
                    <strong>{social.label}</strong>
                    <small>{social.value}</small>
                  </span>
                  <span class="card-action" aria-hidden="true">{social.action} ↗</span>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>

      <footer class="footer shell">
        <p>© {new Date().getFullYear()} himehatsumi</p>
        <a href="#top">back to the top ↑</a>
      </footer>
    </section>
  </main>

  <script>
    const hero = document.querySelector<HTMLElement>('[data-hero]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let animationFrame = 0;

    const updateHero = () => {
      animationFrame = 0;
      if (!hero) return;

      if (reducedMotion.matches) {
        hero.style.setProperty('--hero-progress', '0');
        return;
      }

      const scrollDistance = Math.max(hero.offsetHeight - window.innerHeight, 1);
      const progress = Math.min(Math.max(-hero.getBoundingClientRect().top / scrollDistance, 0), 1);
      hero.style.setProperty('--hero-progress', progress.toFixed(3));
    };

    const requestHeroUpdate = () => {
      if (!animationFrame) animationFrame = window.requestAnimationFrame(updateHero);
    };

    updateHero();
    window.addEventListener('scroll', requestHeroUpdate, { passive: true });
    window.addEventListener('resize', requestHeroUpdate, { passive: true });
    reducedMotion.addEventListener('change', requestHeroUpdate);

    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy]');

    copyButton?.addEventListener('click', async () => {
      const text = copyButton.dataset.copy;
      const label = copyButton.querySelector<HTMLElement>('.card-action');
      if (!text || !label) return;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          const input = document.createElement('textarea');
          input.value = text;
          input.setAttribute('readonly', '');
          input.style.position = 'fixed';
          input.style.opacity = '0';
          document.body.appendChild(input);
          input.select();
          const legacyDocument = document as unknown as { execCommand: (command: string) => boolean };
          const copied = legacyDocument.execCommand('copy');
          input.remove();
          if (!copied) throw new Error('Copy was unavailable');
        }

        label.textContent = 'copied!';
        window.setTimeout(() => { label.textContent = 'copy username'; }, 1800);
      } catch {
        label.textContent = `username: ${text}`;
      }
    });
  </script>
</Layout>

<style>
  .skip-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 20;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    color: var(--cream);
    background: var(--ink);
    text-decoration: none;
    transform: translateY(-160%);
    transition: transform 180ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .topbar {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 6.25rem;
  }

  .home-link,
  .social-jump {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .home-link {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-variation-settings: 'SOFT' 80;
  }

  .social-jump {
    padding: 0.65rem 0;
    color: var(--muted);
  }

  .social-jump span {
    display: inline-block;
    margin-left: 0.25rem;
    transition: transform 180ms ease;
  }

  .social-jump:hover span {
    transform: translateY(0.2rem);
  }

  .hero-scroll {
    --hero-progress: 0;
    position: relative;
    height: 165svh;
  }

  .hero-sticky {
    position: sticky;
    top: 0;
    display: grid;
    min-height: 100svh;
    place-items: center;
    overflow: hidden;
    background: linear-gradient(155deg, #fff8fa 0%, #fff0f5 52%, #fbe8ef 100%);
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    opacity: calc(1 - var(--hero-progress) * 1.15);
    filter: blur(calc(var(--hero-progress) * 7px));
    transform: translate3d(0, calc(var(--hero-progress) * -5rem), 0)
      scale(calc(1 - var(--hero-progress) * 0.055));
    transform-origin: center;
    will-change: opacity, transform, filter;
  }

  .welcome {
    margin: 0 0 1.5rem;
    color: var(--muted);
    font-size: clamp(0.78rem, 1.2vw, 0.92rem);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    color: var(--ink);
    font-family: var(--serif);
    font-size: clamp(5.3rem, 14.2vw, 11.5rem);
    font-variation-settings: 'SOFT' 100, 'WONK' 1;
    font-weight: 470;
    letter-spacing: -0.075em;
    line-height: 0.82;
    white-space: nowrap;
  }

  h1 span {
    color: var(--accent);
  }

  .subtitle {
    margin: clamp(2rem, 5vw, 3.25rem) 0 0;
    color: #6d5968;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
  }

  .subtitle span {
    position: relative;
    z-index: 0;
    display: inline-block;
    padding: 0 0.15rem 0.22rem;
  }

  .subtitle span::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: -1;
    height: 0.45rem;
    border-radius: 100%;
    background: rgba(225, 159, 180, 0.42);
    transform: rotate(-1deg) scaleX(0);
    transform-origin: left;
    animation: underline-in 800ms 300ms both cubic-bezier(.2,.8,.2,1);
  }

  @keyframes underline-in {
    to { transform: rotate(-1deg) scaleX(1); }
  }

  .sakura-art {
    position: absolute;
    top: 3%;
    right: -3%;
    z-index: 0;
    width: clamp(30rem, 50vw, 48rem);
    height: auto;
    overflow: visible;
    opacity: calc(0.88 - var(--hero-progress) * 0.42);
    pointer-events: none;
    transform: translate3d(calc(var(--hero-progress) * 3vw), calc(var(--hero-progress) * -3vh), 0);
    will-change: opacity, transform;
  }

  .branch,
  .twig {
    fill: none;
    stroke: #8f5a6c;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .branch {
    stroke-width: 5;
  }

  .branch-fine,
  .twig {
    stroke-width: 2.5;
  }

  .twig {
    stroke: #b77a8f;
    stroke-width: 1.7;
  }

  .petal {
    fill: #e99fb9;
    opacity: calc(0.8 - var(--hero-progress) * 0.25);
    transform-box: fill-box;
    transform-origin: center;
  }

  .petal-one {
    transform: translate3d(calc(var(--hero-progress) * -2rem), calc(var(--hero-progress) * 3rem), 0) rotate(calc(var(--hero-progress) * 35deg));
  }

  .petal-two {
    transform: translate3d(calc(var(--hero-progress) * 1rem), calc(var(--hero-progress) * 2.25rem), 0) rotate(calc(var(--hero-progress) * -28deg));
  }

  .petal-three {
    transform: translate3d(calc(var(--hero-progress) * -1rem), calc(var(--hero-progress) * 3.5rem), 0) rotate(calc(var(--hero-progress) * 22deg));
  }

  .scroll-note {
    position: absolute;
    bottom: clamp(1.5rem, 4vw, 2.75rem);
    left: 50%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    align-items: center;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-decoration: none;
    opacity: calc(1 - var(--hero-progress) * 2.4);
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 1px;
    height: 2.4rem;
    background: currentColor;
    transform-origin: top;
    animation: breathe 1.8s infinite ease-in-out;
  }

  @keyframes breathe {
    50% { transform: scaleY(0.55); opacity: 0.45; }
  }

  .social-section {
    position: relative;
    z-index: 4;
    scroll-margin-top: 0;
    padding-top: clamp(6rem, 11vw, 10rem);
    border-top: 1px solid rgba(169, 88, 120, 0.14);
    background: var(--cream);
  }

  .section-heading {
    max-width: 46rem;
    margin-bottom: clamp(3.5rem, 8vw, 6.5rem);
  }

  .section-heading > p:first-child {
    margin: 0 0 1.25rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.08em;
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(3.4rem, 7.7vw, 6.2rem);
    font-variation-settings: 'SOFT' 80, 'WONK' 1;
    font-weight: 470;
    letter-spacing: -0.055em;
    line-height: 0.91;
  }

  .section-copy {
    max-width: 28rem;
    margin: 2rem 0 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .contact-groups {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(17rem, 0.8fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: start;
  }

  .contact-group h3 {
    margin: 0 0 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.045em;
  }

  .reliable-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-row,
  .other-contact {
    display: grid;
    min-width: 0;
    grid-template-columns: 2.5rem minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    color: var(--ink);
    text-align: left;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .contact-row {
    min-height: 7.6rem;
    padding: 1.3rem 1.45rem;
    border: 1px solid #ebc0cf;
    border-left: 3px solid var(--accent);
    border-radius: 0.55rem;
    background: var(--blush);
  }

  .contact-row:nth-child(2) {
    margin-left: clamp(0rem, 2vw, 1rem);
    background: #f8e2e9;
  }

  .contact-row:nth-child(3) {
    margin-right: clamp(0rem, 2vw, 1rem);
    background: #f6d3df;
  }

  .contact-row:hover,
  .other-contact:hover {
    border-color: var(--accent);
    transform: translateX(0.3rem);
  }

  .other-list {
    border-top: 1px solid var(--line);
  }

  .other-contact {
    min-height: 5.7rem;
    padding: 1rem 0.25rem;
    border-bottom: 1px solid var(--line);
  }

  .icon-wrap {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    color: #84566a;
  }

  .icon-wrap svg {
    width: 1.2rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.4;
  }

  .card-action {
    color: #795666;
    font-size: 0.72rem;
    font-weight: 650;
    white-space: nowrap;
  }

  .social-text {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.25rem;
  }

  .reliable-note {
    order: -1;
    margin-bottom: 0.15rem;
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0.035em;
  }

  .reliable-note span {
    margin-right: 0.25rem;
  }

  .social-text strong {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.3vw, 1.75rem);
    font-variation-settings: 'SOFT' 80;
    font-weight: 520;
    line-height: 1;
  }

  .social-text small {
    color: #655660;
    font-size: 0.83rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .other-contact .social-text strong {
    font-size: 1.25rem;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    margin-top: clamp(6rem, 11vw, 10rem);
    padding-block: 2rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.75rem;
  }

  .footer p {
    margin: 0;
  }

  .footer a {
    text-decoration: none;
  }

  @media (max-width: 860px) {
    .contact-groups {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 640px) {
    .topbar {
      height: 4.75rem;
    }

    .hero-scroll {
      height: 155svh;
    }

    .hero-content {
      filter: none;
      transform: translate3d(0, calc(var(--hero-progress) * -3.5rem), 0)
        scale(calc(1 - var(--hero-progress) * 0.04));
    }

    .welcome {
      margin-bottom: 1.15rem;
    }

    h1 {
      font-size: clamp(3rem, 17vw, 5.1rem);
    }

    .subtitle {
      margin-top: 1.75rem;
      font-size: 0.86rem;
    }

    .sakura-art {
      top: 3%;
      right: -48%;
      width: 32rem;
      opacity: calc(0.68 - var(--hero-progress) * 0.3);
    }

    .flowers use:first-child {
      display: none;
    }

    .contact-row,
    .other-contact {
